generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

enum DeviceType {
  laptop
  desktop
  aio
  server
  other
}

enum AssetStatus {
  in_stock
  waiting_pickup
  in_use
  borrowed
  in_repair
  retired
}

enum AssetRecordAction {
  stock_in
  assign
  cancel_assign
  pick_up
  check_out
  lend
  return
  transfer
  repair
  repair_done
  retire
}

enum RepairResult {
  fixed
  unfixable
}

model User {
  id               Int              @id @default(autoincrement())
  username         String           @unique
  password         String
  realName         String
  accessRoleId     Int
  accessRole       AccessRole       @relation(fields: [accessRoleId], references: [id])
  isActive         Boolean          @default(true)
  mustChangePass   Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  operatorLogs     OperationLog[]  @relation("OperatorLogs")
  assetRecords     AssetRecord[]   @relation("RecordOperator")

  @@index([username])
  @@index([accessRoleId])
}

/** 可配置访问角色：用户通过 accessRoleId 绑定；超级管理员 bypassAll 跳过权限与园区校验 */
model AccessRole {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  bypassAll   Boolean  @default(false)
  campusesAll Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions AccessRolePermission[]
  campuses    AccessRoleCampus[]
  users       User[]
}

model AccessRolePermission {
  id     Int        @id @default(autoincrement())
  roleId Int
  role   AccessRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  key    String

  @@unique([roleId, key])
  @@index([roleId])
}

model AccessRoleCampus {
  id       Int        @id @default(autoincrement())
  roleId   Int
  role     AccessRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  campusId Int
  campus   Campus     @relation(fields: [campusId], references: [id], onDelete: Cascade)

  @@unique([roleId, campusId])
  @@index([roleId])
}

model Campus {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  sortOrder    Int
  isActive     Boolean       @default(true)
  departments  Department[]
  roleCampuses AccessRoleCampus[]
}

model Department {
  id          Int           @id @default(autoincrement())
  campusId    Int
  campus      Campus        @relation(fields: [campusId], references: [id])
  parentId    Int?
  parent      Department?   @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[]  @relation("DepartmentHierarchy")

  name        String
  sortOrder   Int
  isActive    Boolean       @default(true)

  assets      Asset[]
  records     AssetRecord[]

  @@index([campusId, parentId])
  @@index([sortOrder])
}

model AssetTemplate {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  deviceType  DeviceType
  brand       String
  model       String
  os          String
  cpu         String
  memory      String
  storage     String
  remark      String?
  isActive    Boolean     @default(true)
  sortOrder   Int

  assets      Asset[]
}

model Asset {
  id                Int              @id @default(autoincrement())
  assetCode         String           @unique
  templateId        Int?
  template          AssetTemplate?  @relation(fields: [templateId], references: [id])

  deviceType        DeviceType
  brand             String
  model             String
  serialNumber      String          @unique
  os                String
  cpu               String
  memory            String
  storage           String

  status            AssetStatus
  currentUserName  String
  departmentId      Int
  department        Department      @relation(fields: [departmentId], references: [id])

  purchaseDate      DateTime
  warrantyExpiry    DateTime?
  remark            String?
  version           Int              @default(1)

  records           AssetRecord[]
  repairRecords    RepairRecord[]
}

model AssetRecord {
  id                    Int                 @id @default(autoincrement())
  assetId               Int
  asset                 Asset               @relation(fields: [assetId], references: [id])

  action                AssetRecordAction
  userName              String
  departmentId          Int
  department            Department         @relation(fields: [departmentId], references: [id])
  actionDate            DateTime
  expectedReturnDate   DateTime?
  proofImage            String?
  remark                String?

  operatorId            Int
  operator              User                @relation(fields: [operatorId], references: [id], name: "RecordOperator")

  requestId            String             @unique
  createdAt            DateTime           @default(now())
}

model RepairRecord {
  id              Int           @id @default(autoincrement())
  assetId         Int
  asset           Asset         @relation(fields: [assetId], references: [id])

  faultDescription String
  repairVendor     String
  repairCost       Float
  repairResult     RepairResult
  startDate        DateTime
  endDate          DateTime
  remark           String?
}

model SystemConfig {
  configKey     String   @id
  configValue   String
  description   String?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
}

model OperationLog {
  id           Int      @id @default(autoincrement())
  operatorId   Int
  operator     User     @relation(fields: [operatorId], references: [id], name: "OperatorLogs")

  action       String
  targetType   String
  targetId     Int
  detail       Json
  ipAddress    String
  createdAt    DateTime @default(now())
}

